{
  "name": "ahsan-ul-alam/laravel-bisbond",
  "description": "Laravel regional business toolkit with dashboard, Bangla formatting, invoice settings, and system explorer.",
  "keywords": [
    "laravel",
    "bangla",
    "bangladesh",
    "regional",
    "invoice",
    "dashboard"
  ],
  "type": "library",
  "license": "MIT",
  "autoload": {
    "psr-4": {
      "AhsanUlAlam\\LaravelBisbond\\": "src/"
    },
    "files": [
      "src/Helpers/helpers.php"
    ]
  },
  "autoload-dev": {
    "psr-4": {
      "AhsanUlAlam\\LaravelBisbond\\Tests\\": "tests/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "AhsanUlAlam\\LaravelBisbond\\LaravelBisbondServiceProvider"
      ],
      "aliases": {
        "Bisbond": "AhsanUlAlam\\LaravelBisbond\\Facades\\Bisbond"
      }
    }
  },
  "require": {
    "php": "^8.2",
    "illuminate/support": "^11.0|^12.0|^13.0",
    "illuminate/view": "^11.0|^12.0|^13.0",
    "illuminate/routing": "^11.0|^12.0|^13.0",
    "illuminate/database": "^11.0|^12.0|^13.0",
    "illuminate/console": "^11.0|^12.0|^13.0",
    "nesbot/carbon": "^2.0|^3.0"
  },
  "require-dev": {
    "orchestra/testbench": "^9.0|^10.0|^11.0",
    "pestphp/pest": "^3.0"
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}